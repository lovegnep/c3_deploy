



x570104_var_FileId 					= 570104

x570104_var_LevelMin					= 60
x570104_var_LevelMax					= 100


x570104_var_ItemId					= 11000372
x570104_var_NeedItemCount				= 1	
x570104_var_ExtraType					=	1 
x570104_var_ExtraCount				=	12000 
x570104_var_BonusItemId				= 11000219



x570104_var_QuestName				= "【兑换】黄紫水火水银"
x570104_var_EnterInfo					= "\n\t1颗#G天然水银#W和12000#G荣誉#W兑换1个#G黄紫水火水银#W。"






function x570104_ProcEnumEvent(varMap, varPlayer, varTalknpc, varQuest)

	TalkAppendButton(varMap, x570104_var_FileId, x570104_var_QuestName,3,1);
	
end




function x570104_DispatchEnterInfo( varMap, varPlayer, varTalknpc )

	StartTalkTask(varMap)

		
		local suipiannum = GetItemCount(varMap, varPlayer, x570104_var_ItemId)                        
		local rongyunum = GetHonor(varMap, varPlayer)                                 
		local strText1 = format("\n\t您现在有#R%d颗#W#G天然水银#W！",suipiannum)  
		local strText2 = format("\n\t您现在有#R%d#W点#G荣誉#W！",rongyunum)                     
		
		  TalkAppendString(varMap,"#Y"..x570104_var_QuestName) 
		  TalkAppendString(varMap,x570104_var_EnterInfo)                                     
		  TalkAppendString(varMap,strText1)                                                           
		  TalkAppendString(varMap,strText2)                                      		                 
			
        AddQuestItemBonus(varMap, x570104_var_BonusItemId,1)
		

	StopTalkTask()
	DeliverTalkInfo(varMap, varPlayer, varTalknpc, x570104_var_FileId, -1);
end





function x570104_ProcAcceptCheck( varMap, varPlayer, varTalknpc )
    return 1
end




function x570104_ProcAccept( varMap, varPlayer )

	x570104_ProcRequestSubmit(varMap, varPlayer);
end









function x570104_ProcEventEntry(varMap, varPlayer, varTalknpc, varScriptFileId, nFlag)

	if nFlag== nil then
		return
	end

	x570104_DispatchEnterInfo( varMap, varPlayer, varTalknpc )
	
end


function x570104_ProcRequestSubmit(varMap, varPlayer)

	local iRet = x570104_CheckRequest(varMap, varPlayer)

	if iRet>0 then
		x570104_ProcApproveRequest(varMap, varPlayer)
	end
end

function x570104_CheckRequest(varMap, varPlayer)

	

	local ItemCnt = GetItemCount( varMap, varPlayer, x570104_var_ItemId )

	if ItemCnt<x570104_var_NeedItemCount then
		local varStr =  format("天然水银不足%d个！",x570104_var_NeedItemCount)

		StartTalkTask(varMap);
			TalkAppendString(varMap, varStr);
		StopTalkTask();

		DeliverTalkTips(varMap, varPlayer);
		return 0;
	end

	local nExtraCount = 0

	if x570104_var_ExtraType==1 then		
		nExtraCount = GetHonor(varMap, varPlayer)
	elseif x570104_var_ExtraType==2 then	
		nExtraCount = GetShengWang( varMap, varPlayer )
    elseif x570104_var_ExtraType==3 then  
        nExtraCount = GetMoney( varMap, varPlayer, 0 )
    elseif x570104_var_ExtraType==4 then  
        nExtraCount = GetGuildUserPoint( varMap, varPlayer )
	else
		return 0;
	end

	if nExtraCount<x570104_var_ExtraCount then
		local varStr = ""

		if x570104_var_ExtraType==1 then		
			varStr = format("您荣誉不足%d！",x570104_var_ExtraCount)
		elseif x570104_var_ExtraType==2 then	
			varStr = format("您声望不足%d！",x570104_var_ExtraCount)
		elseif x570104_var_ExtraType==3 then  
			varStr = format("您现银不足%d两！",x570104_var_ExtraCount/1000)
        elseif x570104_var_ExtraType==4 then  
   			varStr = format("您帮贡不足%d！",x570104_var_ExtraCount)
        else
			return 0;
		end

		StartTalkTask(varMap);
			TalkAppendString(varMap, varStr);
		StopTalkTask();

		DeliverTalkTips(varMap, varPlayer);
		return 0;
	end

	

	return 1;
	
end

function x570104_ProcApproveRequest(varMap, varPlayer)

	if x570104_GetBonus(varMap, varPlayer)>0 then
		if DelItem(varMap, varPlayer,x570104_var_ItemId,x570104_var_NeedItemCount) ~= 1 then return 0 end

	
		local nExtraCount;
		local iRet=-1;
		if x570104_var_ExtraType==1 then		
			nExtraCount = GetHonor(varMap, varPlayer)
			iRet = SubHonor(varMap, varPlayer,x570104_var_ExtraCount)
		elseif x570104_var_ExtraType==2 then	
			nExtraCount = GetShengWang( varMap, varPlayer )
			iRet = SetShengWang(varMap, varPlayer, nExtraCount-x570104_var_ExtraCount)
		elseif x570104_var_ExtraType==3 then  
            nExtraCount = GetMoney(varMap, varPlayer, 0 )
            CostMoney(varMap, varPlayer, 0, x570104_var_ExtraCount)            
        elseif x570104_var_ExtraType==4 then  
            nExtraCount = GetGuildUserPoint( varMap, varPlayer )
            SubGuildUserPoint(varMap,varPlayer,x570104_var_ExtraCount)
		else
			return 0;
		end

		
		

			
		
	end
		
	
	
end


function x570104_GetBonus(varMap, varPlayer)
	StartItemTask(varMap)
	ItemAppendBind( varMap, x570104_var_BonusItemId, 1 )
	
	local varRet = StopItemTask(varMap,varPlayer)
	if varRet > 0 then
		DeliverItemListSendToPlayer(varMap,varPlayer)
		StartTalkTask(varMap)
			TalkAppendString(varMap,"兑换成功！")
		StopTalkTask(varMap)
		DeliverTalkTips(varMap,varPlayer)
		return 1;
	else
		StartTalkTask(varMap)
		TalkAppendString(varMap,"物品栏已满，无法得到物品！")
		StopTalkTask(varMap)
		DeliverTalkTips(varMap,varPlayer)
		return 0;
	end
end

